---
import { Image } from "astro:assets";
import type { Hobby } from "../interfaces/hobby";

interface Props {
  hobby: Hobby;
}

const { hobby } = Astro.props;
---

<figure class="flex flex-col items-center gap-4">
  <div
    class="glassy-border aspect-square overflow-hidden rounded-xl transition-transform hover:-rotate-3"
  >
    <Image
      alt={hobby.name}
      class="sepia-50"
      src={hobby.imageSrc}
      loading="lazy"
      width={300}
      height={300}
    />
  </div>
  <figcaption>{hobby.name}</figcaption>
</figure>
