---
import { Image } from "astro:assets";

interface Props {
  imageSrc: string;
  title: string;
}

const { imageSrc, title } = Astro.props;
---

<figure class="flex flex-col items-center gap-4">
  <div
    class="glassy-border aspect-square overflow-hidden rounded-xl transition-transform hover:-rotate-3"
  >
    <Image
      alt={title}
      class="sepia-50"
      src={imageSrc}
      loading="lazy"
      width={300}
      height={300}
    />
  </div>
  <figcaption>{title}</figcaption>
</figure>
