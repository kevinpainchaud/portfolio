---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="centered-container flex flex-col gap-6 md:flex-row md:gap-8">
  <div
    class="w-full max-w-40 shrink-0 text-xl font-semibold md:text-base md:font-normal"
  >
    {title}
  </div>
  <div class="flex grow flex-col gap-6">
    <slot />
  </div>
</div>
