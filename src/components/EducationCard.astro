---
import { Image } from "astro:assets";

interface Props {
  name: string;
  period: string;
  university: {
    logoSrc: string;
    name: string;
    websiteUrl: string;
  };
}

const { name, period, university } = Astro.props;
---

<div
  class="flat-border-with-shadow flex items-center gap-4 rounded-xl p-4 md:p-6"
>
  <div
    class="flat-border flex size-14 shrink-0 items-center justify-center rounded-lg md:size-20"
  >
    <Image
      alt={`Logo ${university.name}`}
      src={university.logoSrc}
      class="size-10/12 rounded"
      width={80}
      height={80}
    />
  </div>
  <div class="flex flex-col gap-1">
    <div class="font-medium">{name}</div>
    <div>
      <a href={university.websiteUrl} target="_blank">{university.name}</a>
    </div>
    <div class="text-sm text-olive-600 dark:text-olive-400">{period}</div>
  </div>
</div>
